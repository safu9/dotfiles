[user]
	name = safu9
	email = safu9.dev@gmail.com
[core]
	autocrlf = input
[init]
	defaultBranch = main
[submodule]
	recurse = true
[fetch]
	prune = true
	recurseSubmodules = on-demand # place after submodule.recurse
[pull]
	ff = only
	autostash = true
[push]
	autoSetupRemote = true
[rebase]
	autosquash = true

[alias]
	a = add
	aa = add -A
	b = branch
	bd = branch -d
	bdf = branch -d --force
	bm = branch -m
	bu = branch --unset-upstream
	c = commit
	ca = commit --amend
	can = commit --amend --no-edit
	carn = commit --amend --reset-author --no-edit
	cf = commit --fixup
	cm = commit -m
	co = checkout
	cob = checkout -b
	cod = checkout develop
	com = checkout main
	cp = cherry-pick
	d = diff
	dc = diff --cached
	ds = diff --staged
	f = fetch
	fo = fetch origin
	l = log
	lo = log --oneline
	lg = log --graph --oneline --all
	m = merge
	mf = merge --ff-only
	mn = merge --no-ff
	mdf = merge develop --ff-only
	mdn = merge develop --no-ff
	mmf = merge main --ff-only
	mmn = merge main --no-ff
	p = pull
	ps = push
	psf = push --force-with-lease
	r = reset
	rh = reset --hard
	rhh = reset --hard HEAD
	rb = rebase
	rba = rebase --abort
	rbc = rebase --continue
	rbi = rebase -i
	rbd = rebase develop
	rbm = rebase main
	rs = restore
	rss = restore --staged
	s = switch
	sc = switch -c
	sd = switch develop
	sm = switch main
	ss = status
	st = stash -u
	std = stash drop
	stl = stash list
	stp = stash pop
	stu = stash -u

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
